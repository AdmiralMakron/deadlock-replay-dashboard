@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="chart-container" style="position: relative; height: @Height; width: 100%;">
    <canvas id="@CanvasId"></canvas>
</div>

@code {
    private string CanvasId { get; } = $"chart-{Guid.NewGuid():N}";
    private DotNetObjectReference<Chart>? _selfRef;

    [Parameter, EditorRequired] public object Config { get; set; } = default!;
    [Parameter] public string Height { get; set; } = "320px";
    /// <summary>
    /// Fired when the user clicks an element in the chart. The argument is the
    /// data index (label index) of the clicked point/bar. Only fires when the
    /// chart's <c>options.deadlockExtras.onClickIndex</c> is true.
    /// </summary>
    [Parameter] public EventCallback<int> OnPointClicked { get; set; }

    [JSInvokable]
    public Task OnPointClickedJs(int index) =>
        OnPointClicked.HasDelegate ? OnPointClicked.InvokeAsync(index) : Task.CompletedTask;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && OnPointClicked.HasDelegate)
        {
            _selfRef = DotNetObjectReference.Create(this);
        }
        // Re-render whenever the parent updates the config object reference.
        await JS.InvokeVoidAsync("deadlockCharts.render", CanvasId, Config, _selfRef);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("deadlockCharts.destroy", CanvasId);
        }
        catch (JSDisconnectedException) { /* page tearing down */ }
        catch (TaskCanceledException) { /* page tearing down */ }
        _selfRef?.Dispose();
    }
}

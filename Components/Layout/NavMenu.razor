@inject DeadlockReplayService Replays
@implements IDisposable
@rendermode InteractiveServer

@*
    The hamburger toggle and brand link live in MainLayout's top-row.
    NavMenu only renders the actual nav items.
*@
<div class="nav-scrollable">
    <nav class="nav flex-column">
        <div class="nav-section-label">Navigation</div>
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                Home
            </NavLink>
        </div>

        @{
            var matches = Replays.LoadedMatches;
        }
        @if (matches.Count > 0)
        {
            <div class="nav-section-label">Matches</div>
            @foreach (var m in matches)
            {
                <div class="nav-item">
                    <NavLink class="nav-link" href="@($"dashboard/{m.SourceFileName}")">
                        @System.IO.Path.GetFileNameWithoutExtension(m.SourceFileName)
                    </NavLink>
                </div>
            }
        }
        else
        {
            <div class="nav-empty-hint">No matches loaded yet.</div>
        }
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        Replays.MatchesChanged += OnMatchesChanged;
    }

    private void OnMatchesChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Replays.MatchesChanged -= OnMatchesChanged;
    }
}

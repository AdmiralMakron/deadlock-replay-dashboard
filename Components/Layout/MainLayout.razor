@inherits LayoutComponentBase

@*
    Hamburger sidebar pattern: a hidden checkbox above .page captures the
    drawer's open/closed state. Sibling CSS in MainLayout.razor.css selects
    .nav-toggle:checked ~ .page .sidebar to slide it in. Pure CSS, no JS.
*@
<input type="checkbox" id="dl-nav-toggle" class="nav-toggle" />

<div class="page">
    <header class="top-row">
        <label for="dl-nav-toggle" class="nav-toggle-label" aria-label="Toggle navigation menu">
            <span class="hamburger-bars"></span>
        </label>
        <a href="" class="brand-link">Deadlock Dashboard</a>
        <div class="top-row-spacer"></div>
        <a href="https://github.com/AdmiralMakron/deadlock-replay-dashboard"
           target="_blank" rel="noopener noreferrer"
           class="external-link">
            GitHub
        </a>
    </header>

    <aside class="sidebar">
        <NavMenu />
    </aside>

    @* Backdrop sits behind the drawer; clicking it closes the menu. *@
    <label for="dl-nav-toggle" class="sidebar-backdrop" aria-hidden="true"></label>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
